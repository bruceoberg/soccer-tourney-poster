#. Abbreviations for the group stage sections of the poster.
msgid "### section: group - see notes ###"
msgstr ""

#. Abbreviation of "Goals Against". Shown in a very small area. Indicates
#. goals scored against
#. the team. Not related to 'points'.
msgctxt "group.goals-against"
msgid "GA"
msgstr "GC"

#. Abbreviation of "Goals For". Shown in a very small area. Indicates goals
#. the team scored.
#. Not related to 'points'.
msgctxt "group.goals-for"
msgid "GF"
msgstr "GF"

#. Abbreviation of "Points". Shown in a very small area. Indicates the
#. 'points' of
#. football standings (win=3pts, tie=1pt). Not related to goals.
msgctxt "group.points"
msgid "Pts"
msgstr "Pts"

msgctxt "group.title"
msgid "Group"
msgstr "Grupo"

msgid "### section: match - see notes ###"
msgstr ""

#. How to abbreviate the term 'After Extra Time'.
msgctxt "match.after-extra-time"
msgid "(AET)"
msgstr "(DP)"

#. How to format an ordinal match number.
msgctxt "match.format.label"
msgid "#{id}"
msgstr "n° {id}"

