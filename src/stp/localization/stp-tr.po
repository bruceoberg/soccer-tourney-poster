#. Abbreviations for the group stage sections of the poster.
#, read-only
msgid "### section: group - see notes ###"
msgstr ""

#. ABBREVIATION. Shown in a very small area. Indicates goals scored against
#. the team. Not related to 'points'.
msgctxt "group.goals-against"
msgid "GA"
msgstr "Y"

#. ABBREVIATION. Shown in a very small area. Indicates goals the team scored.
#. Not related to 'points'.
msgctxt "group.goals-for"
msgid "GF"
msgstr "A"

#. ABBREVIATION. Shown in a very small area. Indicates the 'points' of
#. football standings (win=3pts, tie=1pt). Not related to goals.
msgctxt "group.points"
msgid "Pts"
msgstr "P"

msgctxt "group.title"
msgid "Group"
msgstr "Grup"

