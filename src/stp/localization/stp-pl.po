#. This project supports a poster showing the fixtures or results of a
#. football (soccer) tournament. In all cases, shorter translations are
#. preferred. Country names will be shrunk to fit, but many other fields will
#. just overflow. In general, the translation approach should match that of a
#. newspaper or sports page. Be brief and colloquial, not vebose or technical.
#. We're aiming for a casual readership.
msgid "### overview - see notes ###"
msgstr ""

#. Name of the poster- shown in the poster header. Inserted into the {name}
#. field of page.format.title. Year goes before or after, according to that
#. key.
msgid "### section: competition - see notes ###"
msgstr ""

msgctxt "competition.mens-club-world-cup"
msgid "Club World Cup"
msgstr "Klubowe MŚ"

msgctxt "competition.mens-copa-america"
msgid "Copa América"
msgstr "Copa América"

msgctxt "competition.mens-euro"
msgid "Euro"
msgstr "Euro"

msgctxt "competition.mens-world-cup"
msgid "World Cup"
msgstr "Mistrzostwa Świata"

#. The "WC" here is an abbreviation for "World Cup".
#. We want this title to be distinct from the mens
#. World Cup without being too long.
msgctxt "competition.womens-world-cup"
msgid "Women's WC"
msgstr "MŚ Kobiet"

#. Host country or region - shown in poster header, but in limited space.
#. Inserted into the {location} field of page.format.dates-and-location. Date
#. range goes before or after, according to that key.
msgid "### section: host - see notes ###"
msgstr ""

msgctxt "host.au-nz"
msgid "AU/NZ"
msgstr "AU/NZ"

msgctxt "host.brazil"
msgid "Brazil"
msgstr "Brazylia"

msgctxt "host.germany"
msgid "Germany"
msgstr "Niemcy"

msgctxt "host.north-america"
msgid "North America"
msgstr "Ameryka Północna"

msgctxt "host.qatar"
msgid "Qatar"
msgstr "Katar"

msgctxt "host.russia"
msgid "Russia"
msgstr "Rosja"

msgctxt "host.saudi-arabia"
msgid "Saudi Arabia"
msgstr "Arabia Saudyjska"

msgctxt "host.uk-ireland"
msgid "UK & Ireland"
msgstr "WB & Irlandia"

msgctxt "host.usa"
msgid "USA"
msgstr "USA"

#. Title text and layout. If in doubt, leave alone.
msgid "### section: page - see notes ###"
msgstr ""

#. Date range is built and inserted into {dates} field. Country from 'host'
#. section is inserted into {location} field.
msgctxt "page.format.dates-and-location"
msgid "{dates}, {location}"
msgstr "{dates}, {location}"

#. Timezone is build and inserted into {timezone} field. Text from
#. page.timezone.label is inserted into {label} field. Farsi version includes
#. an invisible RtL character so that parenthesis apprear correctly.
msgctxt "page.format.timezone"
msgid "{label}: {timezone}"
msgstr "{label}: {timezone}"

#. Layout of the poster title (centered, on top). Specifies order of year,
#. competition title (from competition section), and poster label
#. (fixtures/results)
msgctxt "page.format.title"
msgid "{year} {name} · {label}"
msgstr "{year} {name} · {label}"

#. Inserted into the {label} of page.format.timezone.
msgctxt "page.timezone.label"
msgid "Time Zone"
msgstr "Strefa czasowa"

#. Inserted into page.format.title when poster shows upcoming matches with no
#. scores.
msgctxt "page.title.fixtures"
msgid "Fixtures"
msgstr "Mecze"

#. Inserted into page.format.title when poster shows completed matches with
#. scores.
msgctxt "page.title.results"
msgid "Results"
msgstr "Wyniki"

#. Names of the stages of a soccer tournament.
msgid "### section: stage - see notes ###"
msgstr ""

msgctxt "stage.final"
msgid "Final"
msgstr "Finał"

msgctxt "stage.group"
msgid "Group Stage"
msgstr "Faza grupowa"

#. Caution. A literal translation of 'Round of' may be inappropriate. Some
#. languages use forms like 'eighths final' or 'sixteenths final'.
msgctxt "stage.quarters"
msgid "Quarter-Finals"
msgstr "Ćwierćfinały"

#. Caution. A literal translation of 'Round of' may be inappropriate. Some
#. languages use forms like 'eighths final' or 'sixteenths final'.
msgctxt "stage.round16"
msgid "Round of Sixteen"
msgstr "1/8 finału"

#. Caution. A literal translation of 'Round of' may be inappropriate. Some
#. languages use forms like 'eighths final' or 'sixteenths final'.
msgctxt "stage.round32"
msgid "Round of Thirty Two"
msgstr "1/16 finału"

#. Caution. A literal translation of 'Round of' may be inappropriate. Some
#. languages use forms like 'eighths final' or 'sixteenths final'.
msgctxt "stage.round64"
msgid "Round of Sixty Four"
msgstr "1/32 finału"

msgctxt "stage.semis"
msgid "Semi-Finals"
msgstr "Półfinały"

msgctxt "stage.third"
msgid "Third Place"
msgstr "O 3. miejsce"

#. Abbreviations for the group stage sections of the poster.
msgid "### section: group - see notes ###"
msgstr ""

#. Abbreviation of "Goals Against". Shown in a very small area. Indicates
#. goals scored against
#. the team. Not related to 'points'.
msgctxt "group.goals-against"
msgid "GA"
msgstr "S-"

#. Abbreviation of "Goals For". Shown in a very small area. Indicates goals
#. the team scored.
#. Not related to 'points'.
msgctxt "group.goals-for"
msgid "GF"
msgstr "S+"

#. Abbreviation of "Points". Shown in a very small area. Indicates the
#. 'points' of
#. football standings (win=3pts, tie=1pt). Not related to goals.
msgctxt "group.points"
msgid "Pts"
msgstr "Pkt"

msgctxt "group.title"
msgid "Group"
msgstr "Grupa"

msgid "### section: match - see notes ###"
msgstr ""

#. How to abbreviate the term 'After Extra Time'.
msgctxt "match.after-extra-time"
msgid "(AET)"
msgstr "(dogr)"

#. How to format an ordinal match number.
msgctxt "match.format.label"
msgid "#{id}"
msgstr "{id}."

