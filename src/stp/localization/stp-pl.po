#. Title text and layout. If in doubt, leave alone.
msgid "### section: page - see notes ###"
msgstr ""

#. Date range is built and inserted into {dates} field. Country from 'host'
#. section is inserted into {location} field.
#, fuzzy
msgctxt "page.format.dates-and-location"
msgid "{dates}, {location}"
msgstr "{dates}, {location}"

#. Timezone is build and inserted into {timezone} field. Text from
#. page.timezone.label is inserted into {label} field. Farsi version includes
#. an invisible RtL character so that parenthesis apprear correctly.
#, fuzzy
msgctxt "page.format.timezone"
msgid "{label}: {timezone}"
msgstr "{label}: {timezone}"

#. Layout of the poster title (centered, on top). Specifies order of year,
#. competition title (from competition section), and poster label
#. (fixtures/results)
#, fuzzy
msgctxt "page.format.title"
msgid "{year} {name} · {label}"
msgstr "{year} {name} · {label}"

#. Inserted into the {label} of page.format.timezone.
#, fuzzy
msgctxt "page.timezone.label"
msgid "Time Zone"
msgstr "Strefa czasowa"

#. Inserted into page.format.title when poster shows upcoming matches with no
#. scores.
